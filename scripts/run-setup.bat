@echo off
REM ===========================================================================
REM RK7 Analytics — Установщик для Windows (BAT-обёртка для PowerShell)
REM ===========================================================================
REM Двойной клик по этому файлу запустит PowerShell-установщик.

REM Проверяем, что запущено из правильной папки
cd /d "%~dp0\.."

REM Разрешаем выполнение скриптов для текущего пользователя
powershell -NoProfile -ExecutionPolicy Bypass -File "%~dp0setup-windows.ps1"

pause
